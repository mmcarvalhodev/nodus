{
    "manifest_version":  3,
    "name":  "NODUS - AI Idea Capture",
    "version":  "4.176.0",
    "description":  "Capture, organize and reuse ideas from supported AI conversations in one organized workspace.",
    "icons":  {
                  "16":  "icons/nodus-16.png",
                  "48":  "icons/nodus-48.png",
                  "128":  "icons/nodus-128.png"
              },
    "permissions":  [
                        "storage",
                        "tabs",
                        "activeTab"
                    ],
    "host_permissions":  [
                             "https://chat.openai.com/*",
                             "https://chatgpt.com/*",
                             "https://claude.ai/*",
                             "https://gemini.google.com/*",
                             "https://perplexity.ai/*",
                             "https://*.perplexity.ai/*",
                             "https://copilot.microsoft.com/*",
                             "https://grok.com/*",
                             "https://x.com/*",
                             "https://chat.deepseek.com/*",
                             "https://nodus-worker.mmcarvalho-dev.workers.dev/*",
                             "https://files.oaiusercontent.com/*",
                             "https://*.oaiusercontent.com/*",
                             "https://cdn.openai.com/*",
                             "https://*.anthropic.com/*",
                             "https://storage.googleapis.com/*",
                             "https://*.blob.core.windows.net/*"
                         ],
    "background":  {
                       "service_worker":  "background.js",
                       "type":  "module"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "https://chat.openai.com/*",
                                                "https://chatgpt.com/*",
                                                "https://claude.ai/*",
                                                "https://gemini.google.com/*",
                                                "https://perplexity.ai/*",
                                                "https://*.perplexity.ai/*",
                                                "https://copilot.microsoft.com/*",
                                                "https://grok.com/*",
                                                "https://x.com/*",
                                                "https://chat.deepseek.com/*"
                                            ],
                                "js":  [
                                           "i18n/i18n.js",
                                           "core/tab_tracker.js",
                                           "core/html_to_markdown.js",
                                           "content/modules/license.js",
                                           "content/content.js",
                                           "content/modules/dashboard_modal.js",
                                           "content/modules/dashboard_cards.js",
                                           "content/modules/chains.js",
                                           "content/modules/dashboard_chains.js",
                                           "content/modules/attachments_db.js",
                                           "content/modules/attachments_ui.js",
                                           "content/modules/attachments_drag_bar.js",
                                           "content/modules/attachments_drop_handler.js",
                                           "content/modules/projects.js",
                                           "content/modules/projects_ui.js"
                                       ],
                                "css":  [
                                            "ui/dashboard.css",
                                            "content/modules/attachments_ui.css",
                                            "content/modules/chains_mode.css",
                                            "content/modules/attachments_drag_bar.css",
                                            "content/modules/attachments_drop_handler.css",
                                            "content/modules/projects.css"
                                        ],
                                "run_at":  "document_end"
                            }
                        ],
    "action":  {
                   "default_popup":  "ui/popup.html",
                   "default_icon":  {
                                        "16":  "icons/nodus-16.png",
                                        "48":  "icons/nodus-48.png",
                                        "128":  "icons/nodus-128.png"
                                    },
                   "default_title":  "NODUS - Manage Ideas"
               },
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "i18n/i18n.js",
                                                           "core/html_to_markdown.js",
                                                           "content/modules/license.js",
                                                           "content/modules/all_modules.js",
                                                           "content/modules/attachments_db.js",
                                                           "content/modules/attachments_ui.js",
                                                           "content/modules/attachments_ui.css",
                                                           "content/modules/file_detection.js",
                                                           "content/modules/dashboard_modal.js",
                                                           "content/modules/dashboard_cards.js",
                                                           "content/modules/onboarding.js",
                                                           "content/modules/onboarding.css",
                                                           "modules/state_sync.js",
                                                           "engines/*.js",
                                                           "telemetry/*.js",
                                                           "ui/dashboard.css",
                                                           "icons/*"
                                                       ],
                                         "matches":  [
                                                         "https://chat.openai.com/*",
                                                         "https://chatgpt.com/*",
                                                         "https://claude.ai/*",
                                                         "https://gemini.google.com/*",
                                                         "https://perplexity.ai/*",
                                                         "https://*.perplexity.ai/*",
                                                         "https://copilot.microsoft.com/*",
                                                         "https://grok.com/*",
                                                         "https://x.com/*",
                                                         "https://chat.deepseek.com/*"
                                                     ]
                                     }
                                 ],
    "minimum_chrome_version":  "88",
    "homepage_url":  "https://nodus-ai.app"
}